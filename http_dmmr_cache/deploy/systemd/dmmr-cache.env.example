# Runtime settings for dmmr-cache.service.
# DMMR_LOG_LEVEL is not supported yet.
DMMR_BIND_ADDRESS=127.0.0.1
DMMR_CACHE_PORT=9080
# Keep this distinct from an Nginx HTTP listener on 9081.
DMMR_CLUSTER_PORT=9091
DMMR_DB_PATH=/var/lib/dmmr/cache.db
DMMR_WORKERS=4
DMMR_SOCKET_PATH=/run/dmmr/dmmr_cache.sock
DMMR_SOCKET_MODE=0660
